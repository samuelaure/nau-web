# ── nau-web environment variables ──────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to the repository.

# ── Zazŭ integration ────────────────────────────────────────────────────────
# URL of the Zazŭ service (used to forward contact form submissions).
# nau-web is on Hostinger, Zazŭ is on Hetzner — use the public URL.
ZAZU_URL=

# Static shared secret — must match NAU_WEB_WEBHOOK_SECRET in Zazŭ's env.
NAU_WEB_WEBHOOK_SECRET=
