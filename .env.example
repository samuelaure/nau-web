# ── nau-web environment variables ──────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to the repository.

# ── Zazŭ integration ────────────────────────────────────────────────────────
# Internal URL of the Zazŭ service (used to forward contact form submissions).
# Production: http://zazu:3000  (Docker internal network)
# Local dev:  http://localhost:3001 (or wherever Zazŭ is running)
ZAZU_URL=

# Static shared secret — must match NAU_WEB_WEBHOOK_SECRET in Zazŭ's env.
# Generate with: openssl rand -hex 32
NAU_WEB_WEBHOOK_SECRET=
